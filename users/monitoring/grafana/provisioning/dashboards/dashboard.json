{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 100,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        { "expr": "up{job=\"users-service\"}", "refId": "A" }
      ],
      "title": "Estado del servicio",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 101,
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "expr": "sum(rate(http_request_duration_seconds_count[5m]))", "refId": "A" }
      ],
      "title": "Tráfico total (req/s)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 102,
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        { "expr": "100 * sum(rate(http_request_duration_seconds_count{status_code=~\"5..\"}[5m])) / sum(rate(http_request_duration_seconds_count[5m]))", "refId": "A" }
      ],
      "title": "% de errores 5xx",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 103,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "refId": "A" }
      ],
      "title": "Latencia p95 global",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "pointSize": 5 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sum(increase(http_request_duration_seconds_count{route=\"/api/login\",status_code=\"200\"}[1m]))", "legendFormat": "Logins exitosos", "refId": "A" },
        { "expr": "sum(increase(http_request_duration_seconds_count{route=\"/api/login\",status_code=\"401\"}[1m]))", "legendFormat": "Logins fallidos (credenciales)", "refId": "B" },
        { "expr": "sum(increase(http_request_duration_seconds_count{route=\"/api/register\",status_code=\"200\"}[1m]))", "legendFormat": "Registros nuevos", "refId": "C" }
      ],
      "title": "Autenticación (logins y registros por minuto)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 30, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sum(increase(http_request_duration_seconds_count{route=~\"/play.*\"}[1m]))", "legendFormat": "Peticiones de jugada (/play)", "refId": "A" },
        { "expr": "sum(increase(http_request_duration_seconds_count{route=~\"/game.*\"}[1m]))", "legendFormat": "Peticiones al game manager (/game)", "refId": "B" }
      ],
      "title": "Actividad de juego (jugadas y partidas por minuto)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))", "legendFormat": "p50 {{route}}", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))", "legendFormat": "p95 {{route}}", "refId": "B" }
      ],
      "title": "Latencia por endpoint (p50 y p95)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sum by (route) (increase(http_request_duration_seconds_count[1m]))", "legendFormat": "{{route}}", "refId": "A" }
      ],
      "title": "Tráfico por endpoint (req/min)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 22 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sum by (route, status_code) (increase(http_request_duration_seconds_count{status_code=~\"4..|5..\"}[5m]))", "legendFormat": "{{route}} ({{status_code}})", "refId": "A" }
      ],
      "title": "Errores por endpoint y código de estado (últimos 5 min)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["yovi", "users-service"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "timezone": "",
  "title": "YOVI - Tráfico del User Service",
  "uid": "yovi-users-traffic",
  "version": 2
}